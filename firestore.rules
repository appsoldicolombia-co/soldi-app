rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == "admin@soldi.co";
    }

    // Admin tiene acceso total a todo
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Dueño autenticado: acceso total a su negocio
    match /negocios/{negocioId} {
      allow read, write: if request.auth != null && request.auth.uid == negocioId;
    }
    match /negocios/{negocioId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == negocioId;
    }

    // Acceso público para el enlace de reservas
    match /negocios/{negocioId} { allow read: if true; }
    match /negocios/{negocioId}/servicios/{docId} { allow read: if true; }
    match /negocios/{negocioId}/profesionales/{docId} { allow read: if true; }
    match /negocios/{negocioId}/configuracion/{docId} { allow read: if true; }
    match /negocios/{negocioId}/citas/{docId} { allow read, create: if true; }
  }
}
